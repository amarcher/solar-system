# ElevenLabs Conversational AI Agent ID
VITE_ELEVENLABS_AGENT_ID=

# Cloudflare R2 — used for video hosting
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=solar-system-videos
R2_PUBLIC_URL=https://pub-replace-with-your-token.r2.dev

# Vite / frontend — video CDN URL
# VITE_VIDEO_CDN_URL=https://videos.solarsystem.tech

# Vite / frontend — texture CDN URL (high-res 8K textures)
# If unset, app uses bundled 2K textures from public/textures/2k/
# VITE_TEXTURE_CDN_URL=https://textures.solarsystem.tech

# PostHog — product analytics (free tier: 1M events/month)
# Get your key at https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
