{
    "type": "client",
    "name": "navigate_to_element",
    "description": "Navigate the periodic table app to show details about a specific element. Call this when the user asks about a different element or wants to see one.",
    "response_timeout_secs": 30,
    "disable_interruptions": false,
    "force_pre_tool_speech": false,
    "assignments": [],
    "tool_call_sound_behavior": "auto",
    "tool_error_handling_mode": "auto",
    "parameters": {
        "type": "object",
        "required": [
            "name"
        ],
        "description": "Parameters for the client tool",
        "properties": {
            "name": {
                "type": "string",
                "description": "The element name (e.g. 'Calcium') or symbol (e.g. 'Ca')",
                "is_system_provided": false,
                "dynamic_variable": "",
                "constant_value": ""
            }
        }
    },
    "expects_response": true,
    "dynamic_variables": {
        "dynamicVariablePlaceholders": {}
    },
    "execution_mode": "immediate"
}